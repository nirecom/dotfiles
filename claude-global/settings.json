{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "95"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(**/.env.example)",
      "Read(**/.env.sample)",
      "Read(**/.env.template)",
      "Read(**/.env.dist)",
      "Grep(**/.env.example)",
      "Grep(**/.env.sample)",
      "Grep(**/.env.template)",
      "Grep(**/.env.dist)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(cd * && git status)",
      "Bash(cd * && git status *)",
      "Bash(cd * && git log)",
      "Bash(cd * && git log *)",
      "Bash(cd * && git diff)",
      "Bash(cd * && git diff *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v*)",
      "Bash(git branch --list *)",
      "Bash(git branch --show-current)",
      "Bash(git branch --contains *)",
      "Bash(git tag)",
      "Bash(git tag -l *)",
      "Bash(git tag --list *)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git rev-parse *)",
      "Bash(git stash list)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(ls * | head *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command -v *)",
      "Bash(uname *)",
      "Bash(pwd)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git -C * push)",
      "Bash(git -C * push origin *)",
      "Bash(git -C * push -u origin *)",
      "Bash(chmod +x *.sh)",
      "Bash(chmod +x */hooks/*)",
      "Write(**/tests/**)",
      "Edit(**/tests/**)",
      "WebSearch",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:learn.microsoft.com)",
      "WebFetch(domain:man7.org)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:platform.openai.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:docs.github.com)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.production)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.env.dev)",
      "Read(**/.env.prod)",
      "Grep(**/.env)",
      "Grep(**/.env.local)",
      "Grep(**/.env.development)",
      "Grep(**/.env.production)",
      "Grep(**/.env.staging)",
      "Grep(**/.env.test)",
      "Grep(**/.env.dev)",
      "Grep(**/.env.prod)",
      "Bash(*rm -rf *)",
      "Bash(*rm -fr *)",
      "Bash(*find *-exec *)",
      "Bash(*find *-execdir *)",
      "Bash(*find *-ok *)",
      "Bash(*find *-okdir *)",
      "Bash(*find *-delete*)",
      "Bash(*find *-fprint*)",
      "Bash(*find *-fls*)",
      "Bash(*sudo *)",
      "Bash(*mkfs *)",
      "Bash(dd *)",
      "Bash(*&& dd *)",
      "Bash(*; dd *)",
      "Bash(*| dd *)",
      "Bash(*git push --force*)",
      "Bash(*git push *--force*)",
      "Bash(*git push --force-with-lease*)",
      "Bash(*git push *--force-with-lease*)",
      "Bash(*git push --mirror*)",
      "Bash(*git push *--mirror*)",
      "Bash(*git push --delete*)",
      "Bash(*git push *--delete*)",
