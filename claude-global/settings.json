{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/claude-global/hooks/check-private-info.js",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read(**/.env.example)",
      "Grep(**/.env.example)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git -C * status)",
      "Bash(git -C * status *)",
      "Bash(git -C * log)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff)",
      "Bash(git -C * diff *)",
      "Bash(cd * && git status)",
      "Bash(cd * && git status *)",
      "Bash(cd * && git log)",
      "Bash(cd * && git log *)",
      "Bash(cd * && git diff)",
      "Bash(cd * && git diff *)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch -v*)",
      "Bash(git branch --list *)",
      "Bash(git branch --show-current)",
      "Bash(git branch --contains *)",
      "Bash(git tag)",
      "Bash(git tag -l *)",
      "Bash(git tag --list *)",
      "Bash(git remote)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git rev-parse *)",
      "Bash(git stash list)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(find *)",
      "Bash(ls * | head *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command -v *)",
      "Bash(uname *)",
      "Bash(pwd)",
      "Bash(git add .)",
      "Bash(git add -A)",
      "Bash(git add *)",
      "Bash(git -C * add *)",
      "Bash(git push)",
      "Bash(git push origin *)",
      "Bash(git -C * push)",
      "Bash(git -C * push origin *)",
      "Bash(git -C * push -u origin *)",
      "Bash(chmod +x *.sh)",
      "Bash(chmod +x */hooks/*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Grep(**/.env)",
      "Grep(**/.env.*)",
      "Bash(*.env*)",
      "Bash(*rm -rf *)",
      "Bash(*rm -fr *)",
      "Bash(*find *-exec *)",
      "Bash(*find *-execdir *)",
      "Bash(*find *-ok *)",
      "Bash(*find *-okdir *)",
      "Bash(*find *-delete*)",
      "Bash(*find *-fprint*)",
      "Bash(*find *-fls*)",
      "Bash(*sudo *)",
      "Bash(*mkfs *)",
      "Bash(dd *)",
      "Bash(*&& dd *)",
      "Bash(*; dd *)",
      "Bash(*| dd *)",
      "Bash(*git push --force*)",
      "Bash(*git push *--force*)",
      "Bash(*git push --force-with-lease*)",
      "Bash(*git push *--force-with-lease*)",
      "Bash(*git push --mirror*)",
      "Bash(*git push *--mirror*)",
      "Bash(*git push --delete*)",
      "Bash(*git push *--delete*)",
      "Bash(*git commit --amend*)",
      "Bash(*git commit *--amend*)",
      "Bash(*--no-verify*)",
      "Bash(*git reset --hard*)",
      "Bash(*curl *|bash*)",
      "Bash(*curl *| bash*)",
      "Bash(*curl *|sh*)",
      "Bash(*curl *| sh*)",
      "Bash(*wget *|bash*)",
      "Bash(*wget *| bash*)",
      "Bash(*wget *|sh*)",
      "Bash(*wget *| sh*)",
      "Bash(*~/.ssh/*)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.gem/credentials)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.profile)",
      "Edit(~/.bash_profile)",
      "Edit(~/.profile_common)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git -C * commit *)",
      "Bash(cd * && git commit *)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "enableAllProjectMcpServers": false,
  "autoUpdatesChannel": "latest"
}
