#!/bin/bash
# Pre-commit hook: scan staged files for private information
# Skips scanning for repos listed in .context-private/private-repos.txt

set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
SCANNER="$DOTFILES_DIR/bin/check-private-info.sh"
PRIVATE_REPOS="$DOTFILES_DIR/.context-private/private-repos.txt"

# Check if this repo is in the private repo whitelist
if [ -f "$PRIVATE_REPOS" ]; then
    REMOTE_URL="$(git remote get-url origin 2>/dev/null || true)"
    if [ -n "$REMOTE_URL" ]; then
        # Extract owner/repo from SSH or HTTPS URL
        REPO_ID="$(echo "$REMOTE_URL" | sed 's/\.git$//' | sed -E 's#.*[:/]([^/]+/[^/]+)$#\1#')"
        if grep -qFx "$REPO_ID" "$PRIVATE_REPOS"; then
            exit 0
        fi
    fi
fi

# Get staged files (added, copied, modified)
STAGED_FILES="$(git diff-index --cached --name-only --diff-filter=ACM HEAD 2>/dev/null || true)"
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Files to skip
SKIP_PATTERNS="bin/check-private-info.sh|\.private-info-allowlist"

FOUND_VIOLATIONS=0

while IFS= read -r file; do
    # Skip scanner-related files
    if echo "$file" | grep -qE "$SKIP_PATTERNS"; then
        continue
    fi

    # Skip binary files
    if git show ":$file" 2>/dev/null | file --mime - 2>/dev/null | grep -q "binary"; then
        continue
    fi

    # Scan staged content
    if ! git show ":$file" 2>/dev/null | "$SCANNER" --stdin "$file"; then
        FOUND_VIOLATIONS=1
    fi
done <<< "$STAGED_FILES"

if [ "$FOUND_VIOLATIONS" -eq 1 ]; then
    echo ""
    echo "Commit blocked: private information detected in staged files."
    echo "Fix the issues above, or add exceptions to .private-info-allowlist"
    exit 1
fi
exit 0
