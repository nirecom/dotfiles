#!/bin/bash
source $HOME/dotfiles/bin/detectos.sh

# Locale
export LANG=en_US.UTF-8
export LANGUAGE=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LC_NUMERIC=ja_JP.UTF-8
export LC_TIME=ja_JP.UTF-8
export LC_COLLATE=en_US.UTF-8
export LC_MONETARY=ja_JP.UTF-8
export LC_MESSAGES=en_US.UTF-8
export LC_PAPER=ja_JP.UTF-8
export LC_NAME=ja_JP.UTF-8
export LC_ADDRESS=ja_JP.UTF-8
export LC_TELEPHONE=ja_JP.UTF-8
export LC_MEASUREMENT=ja_JP.UTF-8
export LC_IDENTIFICATION=ja_JP.UTF-8

if [ -d /opt/share/terminfo ]; then
    export TERMINFO=/opt/share/terminfo
    export TERM=xterm-256color
elif [ -d /usr/share/terminfo ]; then
    export TERM=xterm-256color
else
    export TERM=xterm
fi
# terraform does not read region from ~/.aws/config.
# ref. https://ja.ojit.com/so/terraform/3413058
if type aws >/dev/null 2>&1 && [ "$OSDIST" != "qnap" ]; then
    export AWS_DEFAULT_REGION=$(aws configure get region --profile default)
fi
#export BASH_SILENCE_DEPRECATION_WARNING=1
#export LSCOLORS=Cxfxcxdxbxegedabagacad
export LSCOLORS=gxfxcxdxbxegedabagacad

# Aliases
alias em='emacs'
alias d='docker'
alias dx='docker exec -it'
alias dc='docker compose'
alias dcb='docker compose build --no-cache --force-rm'
alias dcu='docker compose up -d'
alias dcub='docker compose up -d --build'
alias dcd='docker compose down'
alias g='git'
# gitpush alias: ref. https://qiita.com/ut0n/items/2074623c0b8c1c9ff8e6
gitpush() {
  git add -A
  git commit -m "$*"
  git push origin HEAD
}
alias gd='git diff'
alias gs='git status'
alias gl='git pull'
alias gp=gitpush
alias h=history
alias k='kubectl'
alias pon='predict-on' # zsh
alias poff='predict-off' # zsh
alias psmem='ps aux k -pmem | head -n 10'
alias pscpu='ps aux k -pcpu | head -n 10'
alias tmux='~/dotfiles/bin/tmux.sh'
alias viconfig='vim ~/.ssh/config; aws s3 cp ~/.ssh/config s3://nirecom-home/.ssh/'

case "$OSDIST" in
    "macos" )
        alias ll='ls -alG'
        alias ls='ls -G'
        # airport -I for mac address check
        # ref. https://qiita.com/KEINOS/items/dbee5a53caa124430b1f
        alias airport='/System/Library/PrivateFrameworks/Apple80211.framework/Versions/Current/Resources/airport'
        ;;
    "ubuntu" | "amazon" )
        alias ll='ls -al --color=auto'
        alias ls='ls --color=auto'
        ;;
    * ) # mingw is not supported
        alias ll='ls -al'
esac

if "$ISWSL"; then
    alias open="explorer.exe" # open browser for the same experience as macOS
fi

# make each path unique
# ref. https://qiita.com/key-amb/items/ce39b0c85b30888e1e3b
#uniqpath() {
#    _path=""
#    for _p in $(echo $PATH | tr ':' ' '); do
#        case ":${_path}:" in
#            *:"${_p}":* )
#            ;;
#            * )
#                if [ "$_path" ]; then
#                    _path="$_path:$_p"
#                else
#                    _path=$_p
#                fi
#                ;;
#        esac
#    done
#    PATH=$_path
#    unset _p
#    unset _path
#}
export PATH="$HOME/.local/bin:$PATH:$HOME/.local/share/fnm:$HOME/flutter/bin:$HOME/dotfiles/bin:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"

# Entware (QNAP)
[ -d /opt/bin ] && export PATH="/opt/bin:/opt/sbin:$PATH"

# LM Studio CLI
[ -d "$HOME/.lmstudio/bin" ] && export PATH="$PATH:$HOME/.lmstudio/bin"

if [ "$OSDIST" = "macos" ]; then
    if type /usr/local/bin/brew >/dev/null 2>&1; then
        eval $(/usr/local/bin/brew shellenv)
    fi
    # later 'brew shellenv' will have higher priority
    if "$ISM1" && type /opt/homebrew/bin/brew >/dev/null 2>&1; then
            eval $(/opt/homebrew/bin/brew shellenv)
    fi
fi

# for fnm
if command -v fnm &> /dev/null; then
  eval "$(fnm env)"
fi

# git settings: common part
[ -f ~/completion/git-prompt.sh ] && source ~/completion/git-prompt.sh
GIT_PS1_SHOWUPSTREAM=true
GIT_PS1_SHOWUNTRACKEDFILES=true
GIT_PS1_SHOWDIRTYSTATE=true
GIT_PS1_SHOWSTASHSTATE=true

# Setup ssh-agent
if type keychain >/dev/null 2>&1; then
    # keychain manages ssh-agent lifecycle (macOS, Ubuntu, WSL)
    eval "$(keychain --eval --nogui --quiet --agents ssh id_ed25519 2>/dev/null)"
else
    # Fallback: manual ssh-agent management (mingw, etc.)
    case "$OSDIST" in
        "mingw" )
            if [ -f ~/.ssh-agent ]; then
                . ~/.ssh-agent
            fi
            if [ -z "$SSH_AGENT_PID" ] || ! kill -0 $SSH_AGENT_PID >/dev/null 2>&1; then
                ssh-agent > ~/.ssh-agent
                . ~/.ssh-agent
            fi
            ssh-add -l >& /dev/null || ssh-add
            ;;
    esac
fi

if type git > /dev/null 2>&1; then # if git is installed
    if type pgrep >/dev/null 2>&1; then
    PID=`pgrep -fo bash`
    fi
    if [ -n "$PID" ] && [ $$ != "$PID" ]; then # if first bash process
          echo "git pull ~/dotfiles ..."
          git -C ~/dotfiles pull
    fi
fi

# --- BEGIN temporary: main branch upstream tracking fix ---
# If current branch is master, switch to main
_cur_branch=$(git -C ~/dotfiles branch --show-current 2>/dev/null || true)
if [ "$_cur_branch" = "master" ]; then
    if git -C ~/dotfiles rev-parse --verify main >/dev/null 2>&1; then
        # main already exists (e.g. from fetch) — switch to it and delete master
        git -C ~/dotfiles checkout main
        git -C ~/dotfiles branch -D master
    else
        # main does not exist — rename master to main
        git -C ~/dotfiles branch -m master main
    fi
fi
unset _cur_branch
# Ensure main tracks origin/main
if git -C ~/dotfiles rev-parse --verify main >/dev/null 2>&1; then
    _upstream=$(git -C ~/dotfiles config --get branch.main.remote 2>/dev/null || true)
    if [ -z "$_upstream" ]; then
        git -C ~/dotfiles branch --set-upstream-to=origin/main main
    fi
    unset _upstream
fi
# --- END temporary: main branch upstream tracking fix ---

# --- BEGIN temporary: claude-code → claude-global migration ---
if [ -d ~/dotfiles/claude-global ] && [ ! -L ~/dotfiles/claude-code ]; then
    # Remove empty directory left by git (git doesn't clean up empty dirs after rename)
    if [ -d ~/dotfiles/claude-code ]; then
        rmdir ~/dotfiles/claude-code 2>/dev/null || true
    fi
    ln -s claude-global ~/dotfiles/claude-code
fi
if [ -L ~/.claude/settings.json ]; then
    _target=$(readlink ~/.claude/settings.json 2>/dev/null || true)
    if echo "$_target" | grep -q "claude-code"; then
        echo "Migrating Claude Code symlinks (claude-code → claude-global)..."
        ~/dotfiles/install/linux/dotfileslink.sh
    fi
    unset _target
fi
# --- END temporary: claude-code → claude-global migration ---

# --- BEGIN temporary: commands → skills migration ---
if [ -L ~/.claude/commands ] && [ ! -e ~/.claude/skills ]; then
    echo "Migrating Claude Code symlinks (commands → skills)..."
    rm -f ~/.claude/commands
    ~/dotfiles/install/linux/dotfileslink.sh
fi
# --- END temporary: commands → skills migration ---

# Source code highlighting
case "$OSDIST" in
    "macos" )
        if "$ISM1"; then
            export SHAREDIR="/opt/homebrew/share/source-highlight"
            export LESSOPEN="| /opt/homebrew/bin/src-hilite-lesspipe.sh %s"
        else
            export SHAREDIR="/usr/local/share/source-highlight"
            export LESSOPEN="| /usr/local/bin/src-hilite-lesspipe.sh %s"
        fi
        ;;
    "ubuntu" )
        export SHAREDIR="/usr/share/source-highlight"
        export LESSOPEN="| $SHAREDIR/src-hilite-lesspipe.sh %s"
        ;;
    "amazon" )
        export SHAREDIR="/usr/share/source-highlight"
        export LESSOPEN="| $SHAREDIR/src-hilite-lesspipe.sh %s"
esac
export LESS='-R'

# nvm
case "$OSDIST" in
    "macos" )
        export NVM_DIR="$HOME/.nvm"
        if "$ISM1"; then
            [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && . "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
            [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && . "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion
        else
            [ -s "/usr/local/opt/nvm/nvm.sh" ] && . "/usr/local/opt/nvm/nvm.sh"  # This loads nvm
            # may too heavy on old macbook :(
            [ -s "/usr/local/opt/nvm/etc/bash_completion.d/nvm" ] && . "/usr/local/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion
        fi
        ;;
    "ubuntu" | "amazon" )
        export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
        [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" # This loads nvm
esac

# tmux
if ! "$ISWSL" && [ "$OSDIST" = "ubuntu" ]; then
    ~/dotfiles/bin/tmux.sh
fi
