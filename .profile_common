# Setup ssh-agent
if type keychain >/dev/null 2>&1; then
    # Auto-detect private keys (id_* excluding .pub)
    _ssh_keys=$(find ~/.ssh -maxdepth 1 -name 'id_*' ! -name '*.pub' -printf '%f\n' 2>/dev/null)
    if [ -n "$_ssh_keys" ]; then
        eval "$(keychain --eval --nogui --quiet --agents ssh $_ssh_keys)"
    fi
    unset _ssh_keys
else
    # Fallback: manual ssh-agent management (mingw, etc.)
    case "$OSDIST" in
        "mingw" )
            if [ -f ~/.ssh-agent ]; then
                . ~/.ssh-agent
            fi
            if [ -z "$SSH_AGENT_PID" ] || ! kill -0 $SSH_AGENT_PID >/dev/null 2>&1; then
                ssh-agent > ~/.ssh-agent
                . ~/.ssh-agent
            fi
            ssh-add -l >& /dev/null || ssh-add
            ;;
    esac
fi

if type git > /dev/null 2>&1; then # if git is installed
    if type pgrep >/dev/null 2>&1; then
    PID=`pgrep -fo bash`
    fi
    if [ -n "$PID" ] && [ $$ != "$PID" ]; then # if first bash process
        _dotfiles_private_dir="$(dirname "$DOTFILES_DIR")/dotfiles-private"
        _agents_dir="$(dirname "$DOTFILES_DIR")/agents"
        _session_dir="$HOME/.claude/projects"

        # Suppress zsh job-control output ([N] PID / [N] exit N) via NO_MONITOR
        _dotfiles_fetch_all() {
            [ -n "$ZSH_VERSION" ] && setopt LOCAL_OPTIONS NO_MONITOR
            # Portable timeout: timeout (Linux) → gtimeout (macOS coreutils) → none
            local _tc
            if command -v timeout >/dev/null 2>&1; then
                _tc="timeout 3"
            elif command -v gtimeout >/dev/null 2>&1; then
                _tc="gtimeout 3"
            fi

            # Launch all fetches in parallel
            echo "git fetch $DOTFILES_DIR ..."
            # shellcheck disable=SC2086
            $_tc git -C "$DOTFILES_DIR" fetch 2>/dev/null & _pid_df=$!

            _pid_prv= _rc_prv=1
            if [ -d "$_dotfiles_private_dir/.git" ]; then
                echo "git fetch dotfiles-private ..."
                # shellcheck disable=SC2086
                $_tc git -C "$_dotfiles_private_dir" fetch 2>/dev/null & _pid_prv=$!
            fi

            _pid_ag= _rc_ag=1
            if [ -d "$_agents_dir/.git" ]; then
                echo "git fetch agents ..."
                # shellcheck disable=SC2086
                $_tc git -C "$_agents_dir" fetch 2>/dev/null & _pid_ag=$!
            fi

            _pid_ss= _rc_ss=1
            if [ -d "$_session_dir/.git" ]; then
                echo "git fetch Claude session sync ..."
                # shellcheck disable=SC2086
                $_tc git -C "$_session_dir" fetch 2>/dev/null & _pid_ss=$!
            fi

            # Wait for all fetches
            wait $_pid_df; _rc_df=$?
            [ -n "$_pid_prv" ] && { wait $_pid_prv; _rc_prv=$?; }
            [ -n "$_pid_ag"  ] && { wait $_pid_ag;  _rc_ag=$?;  }
            [ -n "$_pid_ss"  ] && { wait $_pid_ss;  _rc_ss=$?;  }
        }
        _dotfiles_fetch_all
        unset -f _dotfiles_fetch_all 2>/dev/null

        # Merge dotfiles
        if [ "$_rc_df" -eq 0 ]; then
            if ! git -C "$DOTFILES_DIR" merge --ff-only FETCH_HEAD 2>/dev/null; then
                # ff-only failed — check if diverged (force push scenario)
                if ! git -C "$DOTFILES_DIR" merge-base --is-ancestor HEAD FETCH_HEAD 2>/dev/null; then
                    if [ -e "$HOME/.dotfiles-no-auto-reset" ]; then
                        echo "WARNING: dotfiles diverged from origin. Run: git -C $DOTFILES_DIR reset --hard origin/main"
                    elif [[ -t 0 ]]; then
                        echo "dotfiles diverged from origin (force push detected)."
                        echo "Reset to origin/main? Local changes will be lost. [y/N]"
                        read -t 10 -r _ans
                        if [[ "$_ans" =~ ^[Yy]$ ]]; then
                            git -C "$DOTFILES_DIR" reset --hard origin/main
                        else
                            echo "Skipped. Run manually: git -C $DOTFILES_DIR reset --hard origin/main"
                        fi
                    fi
                fi
            fi
        fi
        [ "$_rc_prv" -eq 0 ] && git -C "$_dotfiles_private_dir" merge --ff-only FETCH_HEAD 2>/dev/null
        [ "$_rc_ag"  -eq 0 ] && git -C "$_agents_dir" merge --ff-only FETCH_HEAD 2>/dev/null
        [ "$_rc_ss"  -eq 0 ] && git -C "$_session_dir" merge --ff-only FETCH_HEAD 2>/dev/null

        unset _dotfiles_private_dir _agents_dir _session_dir
        unset _pid_df _pid_prv _pid_ag _pid_ss _rc_df _rc_prv _rc_ag _rc_ss _ans
    fi
fi

# Returns true if any VS Code window is currently open
_any_vscode_window() {
    if [ "$(uname)" = "Darwin" ]; then
        local count
        count=$(osascript -e 'tell application "System Events" to (count (every window of every process whose name contains "Code"))' 2>/dev/null)
        [ "${count:-0}" -gt 0 ]
    elif type xdotool >/dev/null 2>&1; then
        xdotool search --name "Visual Studio Code" 2>/dev/null | grep -q .
    elif type wmctrl >/dev/null 2>&1; then
        wmctrl -l 2>/dev/null | grep -q "Visual Studio Code"
    else
        return 1
    fi
}

# Launch VS Code with session sync (push on close)
codes() {
    local target="${1:-.}"
    local name
    if [[ "$target" == *.code-workspace ]]; then
        name="$(basename "$target" .code-workspace)"
    else
        name="$(basename "$(cd "$target" 2>/dev/null && pwd || echo "$target")")"
    fi
    (
        code --new-window "$@"
        "$DOTFILES_DIR/bin/wait-vscode-window.sh" "$name"
        if _any_vscode_window; then
            "${AGENTS_DIR:-$DOTFILES_DIR}/bin/session-sync.sh" push --quiet
        else
            "${AGENTS_DIR:-$DOTFILES_DIR}/bin/session-sync.sh" push --quiet --toast
        fi
    ) &
    disown
}

