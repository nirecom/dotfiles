      "Bash(*git branch -d*)",
      "Bash(*git push origin :*)",
      "Bash(*git push *origin :*)",
      "Bash(*curl *|bash*)",
      "Bash(*curl *| bash*)",
      "Bash(*curl *|sh*)",
      "Bash(*curl *| sh*)",
      "Bash(*wget *|bash*)",
      "Bash(*wget *| bash*)",
      "Bash(*wget *|sh*)",
      "Bash(*wget *| sh*)",
      "Bash(*~/.ssh/*)",
      "Read(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
