# This is Git's per-user configuration file.
[color]
    ui = auto
[alias]
    br = branch
    ch = checkout
    st = status
    co = commit
    fe = fetch
    gr = log --graph --date-order -C -M --pretty=format:\"<%h> %ad [%an] %Cgreen%d%Creset %s\" --all --date=short
    difff = diff --word-diff
[push]
    default = simple
[user]
    email = 12681101+nirecom@users.noreply.github.com
    name = Hideaki Nire (nirecom)
[fetch]
    prune = true
[pull]
    rebase = false
[init]
    defaultBranch = main
[include]
    path = config.local
